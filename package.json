{
  "name": "claude-punk",
  "version": "0.5.2",
  "description": "BitmapPunks-powered Claude Code companion, adapted from 1270011/claude-buddy",
  "author": "bitmappunks",
  "type": "module",
  "bin": {
    "claude-punk": "./cli/index.ts",
    "claude-buddy": "./cli/index.ts"
  },
  "scripts": {
    "server": "bun run server/index.ts",
    "pick": "bun run cli/pick.ts",
    "hunt": "bun run cli/hunt.ts",
    "install-punk": "bun run cli/install.ts",
    "install-buddy": "bun run cli/install.ts",
    "show": "bun run cli/show.ts",
    "doctor": "bun run cli/doctor.ts",
    "test-statusline": "bun run cli/test-statusline.ts",
    "backup": "bun run cli/backup.ts",
    "settings": "bun run cli/settings.ts",
    "disable": "bun run cli/disable.ts",
    "enable": "bun run cli/install.ts",
    "upgrade": "bun run cli/upgrade.ts",
    "uninstall": "bun run cli/uninstall.ts",
    "help": "bun run cli/index.ts help",
    "buddy-shell": "npx tsx cli/buddy-shell.ts",
    "tui": "bun run cli/tui.tsx",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "gen:emoji-widths": "bun run scripts/gen-emoji-widths.ts"
  },
  "files": [
    "server/",
    "cli/",
    "skills/",
    "hooks/",
    "statusline/",
    "assets/",
    "vendor/bmp-gif/",
    ".claude-plugin/",
    "!**/*.test.ts"
  ],
  "keywords": [
    "claude-code",
    "claude-punk",
    "bitmappunks",
    "bitmap-punks",
    "mcp",
    "terminal-pet",
    "statusline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bitmappunks-com/claude-buddy-bmp.git"
  },
  "homepage": "https://github.com/bitmappunks-com/claude-buddy-bmp#readme",
  "license": "MIT",
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "ink": "^7.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "trustedDependencies": [
    "@homebridge/node-pty-prebuilt-multiarch"
  ]
}
